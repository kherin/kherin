# Astro server
HOST=0.0.0.0
PORT=4321

# Public site URL (used for canonical URLs and sitemap)
PUBLIC_SITE_URL=https://kherin.com

# CMS auth — generate both with: openssl rand -base64 32
CMS_PASSWORD=change-me-in-production
KEYSTATIC_SECRET=change-me-in-production

# Optional: GitHub mode for Keystatic (leave blank for local/Docker mode)
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
# KEYSTATIC_GITHUB_REPO_OWNER=kherin
# KEYSTATIC_GITHUB_REPO_NAME=kherin

---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
---

<BaseLayout
  title="Portfolio"
  description="Open-source projects by Kherin Bundhoo — data science tools, AI experiments, mobile apps, web development, and DevOps automation."
>
  <!-- Page header -->
  <div class="relative py-16 px-6 border-b border-f1-border overflow-hidden bg-f1-dark">
    <div class="absolute inset-0 speed-lines-bg opacity-30 pointer-events-none" aria-hidden="true"></div>
    <div class="relative max-w-6xl mx-auto">
      <div class="sector-label mb-3">Race History</div>
      <h1 class="page-title display text-6xl md:text-8xl text-f1-white">
        PORT<span class="text-f1-red">FOLIO</span>
      </h1>
      <p class="text-f1-grey mt-4 max-w-xl">
        Open-source projects across data science, AI, mobile, and web — all on GitHub.
      </p>
    </div>
  </div>

  <ProjectsSection />

  <!-- GitHub CTA -->
  <section class="py-16 px-6 border-t border-f1-border bg-f1-dark" aria-label="GitHub CTA">
    <div class="max-w-3xl mx-auto text-center reveal">
      <div class="sector-label justify-center mb-4">Pit Lane</div>
      <h2 class="display text-4xl text-f1-white mb-4">
        MORE ON <span class="text-f1-red">GITHUB</span>
      </h2>
      <p class="text-f1-grey mb-8">
        All my repositories — experiments, tooling, practice, and production code — live on GitHub.
      </p>
      <a
        href="https://github.com/kherin"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-f1 inline-flex items-center gap-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        github.com/kherin
      </a>
    </div>
  </section>
</BaseLayout>

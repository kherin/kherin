---
const year = new Date().getFullYear();

const socials = [
  {
    label: 'GitHub',
    href: 'https://github.com/kherin',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>`,
  },
  {
    label: 'Kaggle',
    href: 'https://www.kaggle.com/kherin',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.825 23.859c-.022.092-.117.141-.281.141h-3.139c-.187 0-.351-.082-.492-.248l-5.178-6.589-1.448 1.374v5.111c0 .235-.117.352-.351.352H5.505c-.236 0-.354-.117-.354-.352V.353c0-.233.118-.353.354-.353h2.431c.234 0 .351.12.351.353v14.343l6.203-6.272c.165-.165.33-.246.495-.246h3.239c.144 0 .236.06.285.18.046.149.034.255-.036.315l-6.555 6.344 6.836 8.507c.095.104.117.208.07.334z"/></svg>`,
  },
  {
    label: 'DataCamp',
    href: 'https://www.datacamp.com/portfolio/kherin',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.931 8.67L10.35 7.246c-.198-.11-.428-.11-.626 0l-2.58 1.423A1.246 1.246 0 0 0 6.5 9.773v2.861c0 .453.242.872.644 1.098l2.58 1.424c.2.11.428.11.626 0l.9-.496v2.48l-3.68 2.032-7.07-3.904V7.437L7.57 3.533l4.62 2.55V8.67zm-1.86 6.66l3.68-2.03 7.07 3.904v7.026l-7.07 3.906-3.68-2.032v-2.48l.9.497c.2.11.427.11.626 0l2.58-1.424a1.25 1.25 0 0 0 .644-1.098v-2.86a1.25 1.25 0 0 0-.644-1.1l-2.58-1.42c-.2-.112-.427-.112-.627 0l-.9.496V15.33z"/></svg>`,
  },
];
---

<footer class="border-t border-f1-border bg-f1-dark mt-24" role="contentinfo">
  <!-- Racing stripe -->
  <div class="h-[2px] bg-gradient-to-r from-transparent via-f1-red to-transparent"></div>

  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <!-- Brand -->
      <div>
        <div class="display text-3xl text-f1-white mb-1">KHERIN BUNDHOO</div>
        <p class="font-heading text-sm text-f1-grey tracking-widest uppercase">
          Full-Stack Developer · Data Scientist · Trail Runner
        </p>
        <p class="font-heading text-xs text-f1-grey-dark mt-1 tracking-wider">
          Mauritius 🇲🇺
        </p>
      </div>

      <!-- Nav links -->
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap gap-x-6 gap-y-2 list-none m-0 p-0">
          {[
            ['/', 'Home'],
            ['/about', 'About'],
            ['/portfolio', 'Portfolio'],
            ['/blog', 'Blog'],
          ].map(([href, label]) => (
            <li>
              <a
                href={href}
                class="font-heading text-sm font-600 text-f1-grey hover:text-f1-red tracking-widest uppercase transition-colors duration-200 no-underline"
              >{label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Socials -->
      <div class="flex items-center gap-3">
        {socials.map(({ label, href, icon }) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={label}
            class="w-9 h-9 flex items-center justify-center text-f1-grey hover:text-f1-red border border-f1-border hover:border-f1-red transition-all duration-200"
            set:html={icon}
          />
        ))}
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-6 border-t border-f1-border flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-mono text-xs text-f1-grey-dark">
        © {year} Kherin Bundhoo. Built with Astro & Three.js.
      </p>
      <p class="font-mono text-xs text-f1-grey-dark flex items-center gap-1">
        <span class="inline-block w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
        kherin.com
      </p>
    </div>
  </div>
</footer>

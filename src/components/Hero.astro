---
// Hero component — Three.js F1 speed-lines scene + typographic overlay
---

<section class="relative w-full min-h-screen flex items-center justify-center overflow-hidden bg-f1-black" aria-label="Hero">
  <!-- Three.js canvas fills the section -->
  <canvas
    id="hero-canvas"
    class="absolute inset-0 w-full h-full"
    aria-hidden="true"
  ></canvas>

  <!-- Vignette overlay -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse at center, transparent 30%, rgba(10,10,10,0.7) 100%);"
    aria-hidden="true"
  ></div>

  <!-- Bottom red racing stripe -->
  <div
    class="absolute bottom-0 left-0 right-0 pointer-events-none"
    style="height: 2px; background: linear-gradient(90deg, transparent, #E10600 20%, #E10600 80%, transparent); box-shadow: 0 0 20px rgba(225,6,0,0.5);"
    aria-hidden="true"
  ></div>

  <!-- F1 timing grid lines (background decoration) -->
  <div
    class="absolute inset-0 pointer-events-none opacity-5 speed-lines-bg"
    aria-hidden="true"
  ></div>

  <!-- Hero content -->
  <div class="relative z-10 text-center px-6 max-w-5xl mx-auto">

    <!-- Sector label -->
    <div class="sector-label justify-center mb-5 opacity-0 animate-[fadeUp_0.6s_0.2s_ease_forwards]">
      Full-Stack Developer · Data Scientist · Trail Runner
    </div>

    <!-- Race entry number -->
    <div class="font-mono text-xs text-f1-grey-dark tracking-[0.3em] uppercase mb-1 opacity-0 animate-[fadeUp_0.5s_0.3s_ease_forwards]">
      Mauritius 🇲🇺 &nbsp;·&nbsp; Open to Work
    </div>

    <!-- Main name display -->
    <h1
      class="page-title display text-[clamp(3.5rem,12vw,9rem)] text-f1-white leading-none tracking-wide mb-2 opacity-0 animate-[speedIn_0.8s_0.1s_cubic-bezier(0.16,1,0.3,1)_forwards]"
    >
      KHERIN<br/><span class="text-red-gradient">BUNDHOO</span>
    </h1>

    <!-- Typing roles -->
    <div class="font-heading text-[clamp(1rem,2.5vw,1.35rem)] text-f1-grey tracking-widest uppercase mb-8 h-8 opacity-0 animate-[fadeUp_0.6s_0.5s_ease_forwards]">
      <span id="typing-text"></span><span class="text-f1-red animate-blink">|</span>
    </div>

    <!-- CTA Buttons -->
    <div class="flex flex-wrap justify-center gap-3 opacity-0 animate-[fadeUp_0.6s_0.7s_ease_forwards]">
      <a href="/portfolio" class="btn-f1 text-sm py-3 px-6 gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        Portfolio
      </a>
      <a href="/blog" class="btn-f1 btn-f1-ghost text-sm py-3 px-6 gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        Blog
      </a>
      <a href="/about" class="btn-f1 btn-f1-ghost text-sm py-3 px-6 gap-2">
        About Me
      </a>
    </div>

    <!-- Timing board row (F1 aesthetic) -->
    <div class="mt-12 flex flex-wrap justify-center gap-6 font-mono text-xs opacity-0 animate-[fadeUp_0.6s_0.9s_ease_forwards]">
      {[
        { label: 'Python',      val: '5+ yrs' },
        { label: 'TypeScript',  val: '4+ yrs' },
        { label: 'Open Source', val: 'Active' },
        { label: 'Community',   val: 'PYMUG' },
      ].map(({ label, val }) => (
        <div class="flex flex-col items-center gap-1 border border-f1-border px-3 py-1.5 bg-f1-dark/50 backdrop-blur-sm">
          <span class="text-f1-grey-dark tracking-widest uppercase text-[0.6rem]">{label}</span>
          <span class="text-f1-white font-600 tracking-wider">{val}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 opacity-0 animate-[fadeUp_0.6s_1.2s_ease_forwards]">
    <div class="flex flex-col items-center gap-2 text-f1-grey-dark">
      <span class="font-mono text-[0.6rem] tracking-[0.3em] uppercase">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-f1-grey-dark to-transparent animate-[scan_1.8s_ease-in-out_infinite]"></div>
    </div>
  </div>
</section>

<script>
  // ─── Three.js F1 Speed Scene ─────────────────────────────────────────
  import * as THREE from 'three';

  function initHero() {
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;

    // ── Setup ──────────────────────────────────────────────────────────
    const scene    = new THREE.Scene();
    const camera   = new THREE.PerspectiveCamera(70, window.innerWidth / window.innerHeight, 0.1, 200);
    camera.position.set(0, 0, 7);
    camera.lookAt(0, 0, 0);

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: false });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x080808, 1);

    // ── Speed Streaks ─────────────────────────────────────────────────
    type Streak = { mesh: THREE.Mesh; speed: number };
    const streaks: Streak[] = [];
    const redColors   = [0xE10600, 0xFF3333, 0xFF5555, 0xDD0000];
    const lightColors = [0xFFFFFF, 0xDDDDDD, 0xAAAAAA, 0x888888];

    for (let i = 0; i < 520; i++) {
      const isRed    = i < 130;
      const length   = Math.random() * 6 + 0.4;
      const height   = Math.random() * 0.005 + 0.0015;
      const geometry = new THREE.PlaneGeometry(length, height);
      const palette  = isRed ? redColors : lightColors;
      const color    = palette[Math.floor(Math.random() * palette.length)];

      const material = new THREE.MeshBasicMaterial({
        color,
        transparent: true,
        opacity: Math.random() * 0.45 + (isRed ? 0.1 : 0.04),
        side: THREE.DoubleSide,
        blending: THREE.AdditiveBlending,
        depthWrite: false,
      });

      const mesh = new THREE.Mesh(geometry, material);
      mesh.position.set(
        (Math.random() - 0.5) * 28,
        (Math.random() - 0.5) * 11,
        (Math.random() - 0.5) * 14 - 2
      );
      scene.add(mesh);
      streaks.push({ mesh, speed: Math.random() * 0.38 + 0.06 });
    }

    // ── Racing Lines (horizontal glow) ────────────────────────────────
    const makeHLine = (y: number, opacity: number, h: number) => {
      const geo = new THREE.PlaneGeometry(300, h);
      const mat = new THREE.MeshBasicMaterial({
        color: 0xE10600,
        transparent: true,
        opacity,
        blending: THREE.AdditiveBlending,
        depthWrite: false,
      });
      const m = new THREE.Mesh(geo, mat);
      m.position.set(0, y, -3);
      scene.add(m);
      return mat;
    };
    const lineMat1 = makeHLine(-1.6, 0.75, 0.005);
    const lineMat2 = makeHLine(-1.6, 0.10, 0.07);
    // Subtle top line
    makeHLine(2.2, 0.12, 0.003);

    // ── Particle Dust ─────────────────────────────────────────────────
    const N = 2800;
    const pPos = new Float32Array(N * 3);
    const pVel = new Float32Array(N);
    for (let i = 0; i < N; i++) {
      pPos[i * 3]     = (Math.random() - 0.5) * 42;
      pPos[i * 3 + 1] = (Math.random() - 0.5) * 14;
      pPos[i * 3 + 2] = (Math.random() - 0.5) * 18;
      pVel[i]          = Math.random() * 0.11 + 0.02;
    }
    const pGeo = new THREE.BufferGeometry();
    pGeo.setAttribute('position', new THREE.BufferAttribute(pPos, 3));
    const pMat = new THREE.PointsMaterial({
      color: 0xFFFFFF,
      size: 0.022,
      transparent: true,
      opacity: 0.3,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });
    scene.add(new THREE.Points(pGeo, pMat));

    // ── Wireframe globe (About Mauritius) — subtle bg ─────────────────
    const globeGeo  = new THREE.SphereGeometry(1.8, 20, 20);
    const globeWire = new THREE.WireframeGeometry(globeGeo);
    const globeLines = new THREE.LineSegments(
      globeWire,
      new THREE.LineBasicMaterial({ color: 0x1A1A1A, transparent: true, opacity: 0.25 })
    );
    globeLines.position.set(5.5, -1.5, -8);
    scene.add(globeLines);

    // Mauritius marker: lat -20.2, lon 57.5
    const phi   = (90 - (-20.2)) * (Math.PI / 180);
    const theta = (57.5 + 180)   * (Math.PI / 180);
    const mX = -1.8 * Math.sin(phi) * Math.cos(theta);
    const mY =  1.8 * Math.cos(phi);
    const mZ =  1.8 * Math.sin(phi) * Math.sin(theta);
    const markerGeo = new THREE.SphereGeometry(0.04, 8, 8);
    const markerMat = new THREE.MeshBasicMaterial({ color: 0xE10600, blending: THREE.AdditiveBlending });
    const marker = new THREE.Mesh(markerGeo, markerMat);
    marker.position.set(mX + 5.5, mY - 1.5, mZ - 8);
    scene.add(marker);

    // ── Mouse parallax ────────────────────────────────────────────────
    let tX = 0, tY = 0, cX = 0, cY = 0;
    const onMouse = (e: MouseEvent) => {
      tX =  (e.clientX / window.innerWidth  - 0.5) * 0.9;
      tY = -(e.clientY / window.innerHeight - 0.5) * 0.5;
    };
    window.addEventListener('mousemove', onMouse, { passive: true });

    // ── Animation loop ────────────────────────────────────────────────
    const clock = new THREE.Clock();
    let raf: number;

    const animate = () => {
      raf = requestAnimationFrame(animate);
      const delta = Math.min(clock.getDelta(), 0.05);
      const t     = clock.getElapsedTime();

      // Move streaks left
      for (const { mesh, speed } of streaks) {
        mesh.position.x -= speed * delta * 60 * 0.1;
        if (mesh.position.x < -24) {
          mesh.position.x = 24;
          mesh.position.y = (Math.random() - 0.5) * 11;
          mesh.position.z = (Math.random() - 0.5) * 14 - 2;
        }
      }

      // Move particles
      for (let i = 0; i < N; i++) {
        pPos[i * 3] -= pVel[i] * delta * 60 * 0.04;
        if (pPos[i * 3] < -21) pPos[i * 3] = 21;
      }
      pGeo.attributes.position.needsUpdate = true;

      // Pulse racing line
      lineMat1.opacity = 0.55 + Math.sin(t * 2.8) * 0.2;
      lineMat2.opacity = 0.07 + Math.sin(t * 2.8) * 0.04;

      // Rotate globe
      globeLines.rotation.y += 0.0015;
      marker.position.copy(
        new THREE.Vector3(mX + 5.5, mY - 1.5, mZ - 8).applyEuler(
          new THREE.Euler(0, globeLines.rotation.y, 0)
        )
      );

      // Camera smooth follow
      cX += (tX - cX) * 0.045;
      cY += (tY - cY) * 0.045;
      camera.position.x = cX;
      camera.position.y = cY;
      camera.lookAt(0, -0.2, 0);

      renderer.render(scene, camera);
    };
    animate();

    // ── Resize ────────────────────────────────────────────────────────
    const onResize = () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    };
    window.addEventListener('resize', onResize, { passive: true });

    // Cleanup on navigation
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(raf);
      window.removeEventListener('mousemove', onMouse);
      window.removeEventListener('resize', onResize);
      renderer.dispose();
    }, { once: true });
  }

  // Run on load + re-run after Astro View Transition
  initHero();
  document.addEventListener('astro:after-swap', initHero);

  // ─── Typewriter effect ───────────────────────────────────────────────
  const roles = [
    'Full-Stack Developer',
    'Data Scientist',
    'Mobile Developer',
    'Trail Runner',
    'Open-Source Enthusiast',
  ];

  function startTyping() {
    const el = document.getElementById('typing-text');
    if (!el) return;

    let ri = 0, ci = 0, deleting = false;
    const speed = { type: 65, delete: 35, pause: 1800 };

    const tick = () => {
      const word = roles[ri];
      if (!deleting) {
        el.textContent = word.slice(0, ++ci);
        if (ci === word.length) {
          deleting = true;
          setTimeout(tick, speed.pause);
          return;
        }
      } else {
        el.textContent = word.slice(0, --ci);
        if (ci === 0) {
          deleting = false;
          ri = (ri + 1) % roles.length;
        }
      }
      setTimeout(tick, deleting ? speed.delete : speed.type);
    };

    setTimeout(tick, 800);
  }

  startTyping();
  document.addEventListener('astro:after-swap', startTyping);
</script>
